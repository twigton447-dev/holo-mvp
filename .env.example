# Holo MVP — environment variable template
# Copy to .env and fill in real values. Never commit .env.

# ── LLM Provider Keys (active pool) ────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Bench / Extended Provider Keys ─────────────────────────────────────────
XAI_API_KEY=          # xAI Grok — HC pool / bench pool
MISTRAL_API_KEY=      # Mistral — bench pool
DEEPSEEK_API_KEY=     # DeepSeek — bench pool
MINIMAX_API_KEY=      # MiniMax — bench pool

# ── Governed Web Search (HoloGov-authorized broker; worker-independent) ────
# Search backends never depend on which visible worker is speaking. The broker
# tries HOLOCHAT_SEARCH_PROVIDERS in order and uses the first configured one.
# Supported names: openclaw, openai, xai, gemini, deepseek (custom function).
# OpenClaw is preferred only when its dedicated search-only gateway is enabled.
HOLOCHAT_SEARCH_PROVIDERS=openclaw,openai
# Legacy single-provider pin (used as the first slot if the list above is unset)
HOLOCHAT_SEARCH_PROVIDER=
OPENAI_SEARCH_MODEL=gpt-5.5           # OpenAI hosted web_search model (uses OPENAI_API_KEY)
XAI_SEARCH_MODEL=grok-4.3             # xAI hosted search model (uses XAI_API_KEY)
GEMINI_SEARCH_MODEL=gemini-3.1-pro-preview  # Gemini grounding model (uses GEMINI_API_KEY/GOOGLE_API_KEY)
HOLOCHAT_SEARCH_TIMEOUT_SECONDS=50          # Per-backend attempt cap (10-60 seconds)
HOLOCHAT_SEARCH_MAX_PROVIDER_CALLS=1         # Per-turn hard cost cap; unavailable backends are skipped free
HOLOCHAT_SEARCH_MAX_OUTPUT_TOKENS=1200       # Retrieval + reasoning cap for one hosted search request (256-4096)
HOLOCHAT_SEARCH_MAX_TOOL_CALLS=3             # Total web tool calls allowed inside one hosted request (1-8)
HOLOCHAT_SEARCH_REASONING_EFFORT=low         # OpenAI retrieval effort: none|minimal|low|medium|high|xhigh
# OpenClaw search harness (OFF until a separate gateway is configured for this
# single read-only tool; never point these at a general-purpose gateway).
HOLOCHAT_OPENCLAW_SEARCH_ENABLED=false
HOLOCHAT_OPENCLAW_SEARCH_DEDICATED_GATEWAY=false
HOLOCHAT_OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
HOLOCHAT_OPENCLAW_GATEWAY_TOKEN=
HOLOCHAT_OPENCLAW_SEARCH_SESSION_KEY=holochat-search
HOLOCHAT_OPENCLAW_ALLOW_REMOTE_GATEWAY=false

# ── Third-party Integrations ────────────────────────────────────────────────
RESEND_API_KEY=       # Transactional email
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── Holo Server ─────────────────────────────────────────────────────────────
HOLO_API_KEY=         # API authentication key for the FastAPI server
HOLO_JWT_SECRET=      # JWT signing secret
HOLO_MAX_RPM=         # Optional: requests-per-minute cap
API_BASE_URL=http://localhost:8000
HOLOCHAT_ACCOUNT_ALIASES=  # Optional: alias@example.com:canonical-capsule-id
HOLOCHAT_RUNTIME_PROFILE=holochat_canonical  # canonical HC worker mode; frontier_active requires explicit noncanonical opt-in
HOLOCHAT_MODEL_TIER=frontier  # visible workers: OpenAI GPT-5.5 + xAI Grok 4.3
HOLOCHAT_MODEL_PROVIDERS=openai,xai  # HC worker pool, in rotation order
HOLOCHAT_GOV_PROVIDER=minimax  # private HoloGov proposal compiler; never user-visible
HOLOCHAT_SINGLE_GOV_CALL=1  # exactly one paid HoloGov call; invalid packets fall back to the local kernel
HOLOCHAT_WORKER_GOV_PACKET_MAX_TOKENS=4500  # full canonical ledger stays private; workers receive a bounded projection
MINIMAX_GOV_MODEL=MiniMax-M2.7-highspeed
HOLOCHAT_GOV_TURN_PLAN_OUTPUT_TOKENS=4000
HOLOCHAT_EXPOSE_PRIVATE_RUNTIME=0  # local/operator diagnostics only; never enable for normal public clients
HOLOCHAT_HYBRID_SCOPES_ENABLED=0  # requires reviewed 20260714 scope migration
HOLOCHAT_MEMORY_STEWARD_ENABLED=0  # requires the same migration and checkpoint RPC
HOLOCHAT_MEMORY_IDLE_SECONDS=900  # durable checkpoint after this in-memory idle period
HOLOCHAT_MEMORY_IDLE_SWEEP_SECONDS=60  # background sweep cadence; minimum 30 seconds

# ── Model Overrides (optional — defaults shown) ─────────────────────────────
# Active pool
OPENAI_MODEL=gpt-5.5
ANTHROPIC_MODEL=claude-sonnet-4-6
GOOGLE_MODEL=gemini-2.5-pro
# Bench pool
XAI_MODEL=grok-4.3
MISTRAL_MODEL=mistral-large-latest
DEEPSEEK_MODEL=deepseek-chat
MINIMAX_MODEL=MiniMax-M2.5-highspeed
# HoloChat active pool defaults
OPENAI_FAST_MODEL=gpt-5.5
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
GOOGLE_FAST_MODEL=gemini-2.5-flash-lite
XAI_FAST_MODEL=grok-4.3

# ── Google OAuth (Streamlit frontend) ───────────────────────────────────────
GOOGLE_CLIENT_ID=
