# Holo MVP — environment variable template
# Copy to .env and fill in real values. Never commit .env.

# ── LLM Provider Keys (active pool) ────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Bench / Extended Provider Keys ─────────────────────────────────────────
XAI_API_KEY=          # xAI Grok — HC pool / bench pool
MISTRAL_API_KEY=      # Mistral — bench pool
DEEPSEEK_API_KEY=     # DeepSeek — bench pool
MINIMAX_API_KEY=      # MiniMax — bench pool

# ── Third-party Integrations ────────────────────────────────────────────────
TAVILY_API_KEY=       # Web search for Governor claim verification
RESEND_API_KEY=       # Transactional email
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── Holo Server ─────────────────────────────────────────────────────────────
HOLO_API_KEY=         # API authentication key for the FastAPI server
HOLO_JWT_SECRET=      # JWT signing secret
HOLO_MAX_RPM=         # Optional: requests-per-minute cap
API_BASE_URL=http://localhost:8000
HOLOCHAT_ACCOUNT_ALIASES=  # Optional: alias@example.com:canonical-capsule-id
HOLOCHAT_RUNTIME_PROFILE=holochat_canonical  # canonical HC worker mode; frontier_active requires explicit noncanonical opt-in
HOLOCHAT_MODEL_PROVIDERS=openai,xai  # HC worker pool, in rotation order
HOLOCHAT_EXPOSE_PRIVATE_RUNTIME=0  # local/operator diagnostics only; never enable for normal public clients
HOLOCHAT_HYBRID_SCOPES_ENABLED=0  # requires reviewed 20260714 scope migration
HOLOCHAT_MEMORY_STEWARD_ENABLED=0  # requires the same migration and checkpoint RPC
HOLOCHAT_MEMORY_IDLE_SECONDS=900  # durable checkpoint after this in-memory idle period
HOLOCHAT_MEMORY_IDLE_SWEEP_SECONDS=60  # background sweep cadence; minimum 30 seconds

# ── Model Overrides (optional — defaults shown) ─────────────────────────────
# Active pool
OPENAI_MODEL=gpt-5.5
ANTHROPIC_MODEL=claude-sonnet-4-6
GOOGLE_MODEL=gemini-2.5-pro
# Bench pool
XAI_MODEL=grok-4.3
MISTRAL_MODEL=mistral-large-latest
DEEPSEEK_MODEL=deepseek-chat
MINIMAX_MODEL=MiniMax-M2.5-highspeed
# HoloChat active pool defaults
OPENAI_FAST_MODEL=gpt-5.5
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
GOOGLE_FAST_MODEL=gemini-2.5-flash-lite
XAI_FAST_MODEL=grok-4.3

# ── Google OAuth (Streamlit frontend) ───────────────────────────────────────
GOOGLE_CLIENT_ID=
