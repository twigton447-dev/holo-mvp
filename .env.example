# Holo MVP — environment variable template
# Copy to .env and fill in real values. Never commit .env.

# ── LLM Provider Keys (active pool) ────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Bench / Extended Provider Keys ─────────────────────────────────────────
XAI_API_KEY=          # xAI Grok — HoloChat analyst / bench pool
MISTRAL_API_KEY=      # Mistral — bench pool
DEEPSEEK_API_KEY=     # DeepSeek — bench pool
MINIMAX_API_KEY=      # MiniMax — bench pool

# ── Third-party Integrations ────────────────────────────────────────────────
TAVILY_API_KEY=       # Web search for Governor claim verification
RESEND_API_KEY=       # Transactional email
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── Holo Server ─────────────────────────────────────────────────────────────
HOLO_API_KEY=         # API authentication key for the FastAPI server
HOLO_JWT_SECRET=      # JWT signing secret
HOLO_MAX_RPM=60       # Optional: requests-per-minute cap
API_BASE_URL=http://localhost:8000
HOLOCHAT_ACCOUNT_ALIASES=  # Optional: alias@example.com:canonical-capsule-id
HOLOCHAT_RUNTIME_PROFILE=frontier_active
HOLOCHAT_PROVIDER_ROTATION=xai,openai,minimax
HOLOCHAT_GOVERNOR_PROVIDER=openai
HOLOCHAT_ADAPTER_HISTORY_MESSAGES=8
HOLOCHAT_ADAPTER_HISTORY_CHARS=8000
HOLOCHAT_ADAPTER_HISTORY_MESSAGE_CHARS=1800
HOLOCHAT_LIFE_CONTEXT_CHARS=4000
HOLOCHAT_CAPSULE_CONTEXT_CHARS=3000
HOLOCHAT_CONTEXT_WARNING_TOKENS=20000
HOLOCHAT_CONTEXT_HARD_LIMIT_TOKENS=30000

# ── Model Overrides (optional — defaults shown) ─────────────────────────────
# Active pool
OPENAI_MODEL=gpt-5.4
ANTHROPIC_MODEL=claude-sonnet-4-6
GOOGLE_MODEL=gemini-2.5-pro
# Bench pool
XAI_MODEL=grok-4.3
MISTRAL_MODEL=mistral-large-latest
DEEPSEEK_MODEL=deepseek-chat
MINIMAX_MODEL=MiniMax-Text-01
# Fast tier (FAST evaluations < $10k)
OPENAI_FAST_MODEL=gpt-4o-mini
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
GOOGLE_FAST_MODEL=gemini-2.5-flash-lite
XAI_FAST_MODEL=grok-3-mini

# ── Google OAuth (Streamlit frontend) ───────────────────────────────────────
GOOGLE_CLIENT_ID=
