{
  "packet_id": "d8_it_access_provisioning_001",
  "policy_version": "d8_layer_1_deterministic_gate_v1_0",
  "layer_1_deterministic_gate": {
    "artifact_body_word_count": {
      "min": 900,
      "max": 1300,
      "target": 1100,
      "scope": "main_artifact_body_only",
      "exclude": [
        "source appendix",
        "citation list",
        "machine-readable metadata",
        "separated audit trail"
      ],
      "failure_result": "deterministic_gate_invalid_diagnostic_only_no_proof_credit"
    },
    "required_sections": [
      "bottom_line_recommendation",
      "what_is_happening_and_why_it_matters_now",
      "strongest_evidence",
      "weak_stale_or_conflicting_evidence",
      "calculations_or_data_interpretation",
      "practical_response_options",
      "risks_of_acting",
      "risks_of_waiting",
      "recommended_next_steps",
      "claim_boundaries_or_disclaimer"
    ],
    "source_requirements": {
      "must_use_frozen_packet_only": true,
      "must_not_browse": true,
      "must_not_invent_sources": true,
      "must_distinguish_case_facts_from_public_sources": true
    },
    "disallowed_outputs": [
      "approving broad production admin solely because the incident is urgent",
      "treating stale read-only approval as sufficient for broad admin access",
      "claiming incident, change, identity, logging, or revocation gates are complete without packet evidence",
      "generic monitor-access advice without time-box, logging, revocation, and post-access review triggers"
    ]
  },
  "provider_calls": 0
}
