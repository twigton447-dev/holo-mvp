        },
        "normalized_total_100": {
          "type": "number"
        },
        "raw_total_33": {
          "type": "number"
        },
        "required_repairs_to_next_band": {
          "type": [
            "array",
            "string"
          ]
        },
        "strongest_dimensions": {
          "type": "array"
        },
        "structural_raw_18": {
          "type": "number"
        },
        "structural_scores": {
          "additionalProperties": false,
          "properties": {
            "bluf": {
              "$ref": "#/definitions/dimension_score"
            },
            "data_isolation": {
              "$ref": "#/definitions/dimension_score"
            },
            "evidence_constraints": {
              "$ref": "#/definitions/dimension_score"
            },
            "option_distinctness": {
              "$ref": "#/definitions/dimension_score"
            },
            "risk_symmetry": {
              "$ref": "#/definitions/dimension_score"
            },
            "scannability": {
              "$ref": "#/definitions/dimension_score"
            }
          },
          "required": [
            "bluf",
            "data_isolation",
            "option_distinctness",
            "evidence_constraints",
            "risk_symmetry",
            "scannability"
          ],
          "type": "object"
        },
        "weakest_dimensions": {
          "type": "array"
        }
