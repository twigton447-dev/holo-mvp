            "$ref": "#/definitions/hard_cap"
          },
          "type": "array"
        },
        "artifact_id": {
          "type": "string"
        },
        "band": {
          "type": "string"
        },
        "decision_reliance_risk": {
          "type": "string"
        },
        "dimension_justifications": {
          "type": [
            "object",
            "array",
            "string"
          ]
        },
        "epistemic_raw_15": {
          "type": "number"
        },
        "epistemic_scores": {
          "additionalProperties": false,
          "properties": {
            "claim_evidence_distance": {
              "$ref": "#/definitions/dimension_score"
            },
            "conflicting_data_handling": {
              "$ref": "#/definitions/dimension_score"
            },
            "insight_vs_summary": {
              "$ref": "#/definitions/dimension_score"
            },
            "operational_reality_gap": {
              "$ref": "#/definitions/dimension_score"
            },
            "source_weighting_validity": {
