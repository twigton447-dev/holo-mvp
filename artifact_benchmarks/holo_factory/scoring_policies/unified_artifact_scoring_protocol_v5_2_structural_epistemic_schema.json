  "properties": {
    "artifact_scores": {
      "items": {
        "$ref": "#/definitions/artifact_score"
      },
      "minItems": 1,
      "type": "array"
    },
    "protocol_id": {
      "const": "unified_artifact_scoring_protocol_v5_2_structural_epistemic"
    }
  },
  "required": [
    "protocol_id",
    "artifact_scores"
  ],
  "title": "Unified Artifact Scoring Protocol v5.2 Structural Epistemic Score",
  "type": "object"
}
