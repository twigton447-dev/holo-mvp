  "production_customer_data_flow": [
    {
      "stage": "enterprise_source_system",
      "target_control_goal": "Keep request scoped to the decision being reviewed."
    },
    {
      "stage": "identity_auth_boundary",
      "target_control_goal": "Authenticate caller, bind tenant/request ID, and enforce authorization."
    },
    {
      "stage": "request_validation",
      "target_control_goal": "Reject malformed requests, missing fields, unsupported actions, or invalid tenant routing."
    },
    {
      "stage": "payload_processing_lifecycle",
      "target_control_goal": "Create bounded runtime payload and avoid unnecessary raw transcript accumulation."
    },
    {
      "stage": "model_provider_routing",
      "target_control_goal": "Route minimum required prompt content to approved providers under verified terms."
    },
    {
      "stage": "hologov_governance_selector",
      "target_control_goal": "Combine deterministic checks, governance state, selector rules, model outputs, and source-boundary validation."
    },
    {
      "stage": "holoengine_allow_escalate_response",
      "target_control_goal": "Return ALLOW or ESCALATE without claiming downstream business action execution."
    },
    {
      "stage": "metadata_only_audit_log",
      "target_control_goal": "Log decision metadata without customer payload text by default."
    },
    {
      "stage": "retention_disposal_controls",
      "target_control_goal": "Define retention, disposal, access control, and customer deletion workflows."
    }
  ],
  "program_name": "HoloEngine Trust & Assurance Program",
